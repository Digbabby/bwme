<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@android:drawable/ic_dialog_map"
            android:contentDescription="Map icon"/>

        <TextView
            android:id="@+id/mapPlaceholderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Expense Map"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp"/>

        <TextView
            android:id="@+id/mapPlaceholderDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Map view will show where you spent your money."
            android:textSize="14sp"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:textAlignment="center"/>

        <TextView
            android:id="@+id/mapPlaceholderHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add expenses with location to see them here."
            android:textSize="12sp"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textAlignment="center"/>

    </LinearLayout>
</FrameLayout>