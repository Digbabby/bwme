<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/profile_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="?android:colorBackground"
    tools:context=".ProfileFragment">

    <TextView
        android:id="@+id/labelAllocated"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Budget Allocation"
        android:textStyle="bold"
        android:textColor="?attr/bwme_onSurface"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/profileMonthly"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Enter allocated allowance (numeric)"
        android:inputType="numberDecimal"
        app:layout_constraintTop_toBottomOf="@id/labelAllocated"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/labelAllocationType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Allocation Type"
        android:textColor="?attr/bwme_onSurface"
        app:layout_constraintTop_toBottomOf="@id/profileMonthly"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="12dp"/>

    <Spinner
        android:id="@+id/profilePeriodSpinner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/profileMonthly"
        app:layout_constraintStart_toEndOf="@id/labelAllocationType"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="8dp"/>

    <TextView
        android:id="@+id/labelCalculated"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Calculated Allowance"
        android:textColor="?attr/bwme_onSurface"
        app:layout_constraintTop_toBottomOf="@id/profilePeriodSpinner"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="12dp"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/labelCalculatedPeriodType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Calculated Period Type"
        android:textColor="?attr/bwme_onSurface"
        app:layout_constraintTop_toBottomOf="@id/labelCalculated"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="6dp"/>

    <Spinner
        android:id="@+id/profileCalculatedPeriodSpinner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/labelCalculated"
        app:layout_constraintStart_toEndOf="@id/labelCalculatedPeriodType"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="8dp"/>

    <TextView
        android:id="@+id/profileAllocation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:enabled="false"
        android:focusable="false"
        app:layout_constraintTop_toBottomOf="@id/profileCalculatedPeriodSpinner"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"
        android:textColor="?attr/bwme_onSurface"/>

    <Button
        android:id="@+id/profileSave"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Save"
        app:layout_constraintTop_toBottomOf="@id/profileAllocation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <Button
        android:id="@+id/profileReset"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Reset Expenses"
        app:layout_constraintTop_toBottomOf="@id/profileSave"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/profileAllocatedExpenses"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Allocated Expenses"
        app:layout_constraintTop_toBottomOf="@id/profileReset"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/profileAllocatedTotal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Allocated expenses total: ₱ 0.00"
        app:layout_constraintTop_toBottomOf="@id/profileAllocatedExpenses"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="6dp"
        android:textColor="?attr/bwme_onSurface"/>

    <Button
        android:id="@+id/profileSavings"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Savings"
        app:layout_constraintTop_toBottomOf="@id/profileAllocatedTotal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/profileSavingsTotal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Savings (monthly equiv): ₱ 0.00"
        app:layout_constraintTop_toBottomOf="@id/profileSavings"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="6dp"
        android:textColor="?attr/bwme_onSurface"/>

    <Button
        android:id="@+id/profileLogout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Logout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/profileSavingsTotal" />

    <Switch
        android:id="@+id/switchDarkMode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dark Mode"
        android:textColor="?attr/bwme_onSurface"
        app:layout_constraintTop_toBottomOf="@id/profileLogout"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"/>

    <ImageView
        android:id="@+id/profilepic"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.741"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="1.0"
        tools:src="@tools:sample/avatars" />

    <Button
        android:id="@+id/changebtn"
        android:layout_width="129dp"
        android:layout_height="63dp"
        android:text="Change Picture"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.965" />

    <TextView
        android:id="@+id/profile_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="User Name"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.698" />

</androidx.constraintlayout.widget.ConstraintLayout>